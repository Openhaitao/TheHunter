{
  "manifest_version": 3,
  "name": "TheHunter",
  "version": "1.0.0",
  "description": "智能提取网页联系人和产品信息，通过 AI 分析后自动同步到飞书多维表格",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.siliconflow.cn/*",
    "https://*.feishu.cn/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "TheHunter - 智能信息提取",
    "default_icon": {
      "16": "public/icon-16.png",
      "32": "public/icon-32.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "public/icon-16.png",
    "32": "public/icon-32.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "homepage_url": "https://github.com/yourusername/thehunter"
}

